[{"type": "human", "data": {"content": "\u52a8\u6001\u89c4\u5212", "additional_kwargs": {}, "response_metadata": {}, "type": "human", "name": null, "id": null}}, {"type": "ai", "data": {"content": "# \u52a8\u6001\u89c4\u5212\u8be6\u89e3\n\n## \u95ee\u9898\u7406\u89e3\n\n\u7528\u6237\u63d0\u51fa\u4e86\u201c\u52a8\u6001\u89c4\u5212\u201d\u8fd9\u4e2a\u4e3b\u9898\uff0c\u8fd9\u662f\u4e00\u4e2a\u975e\u5e38\u91cd\u8981\u7684\u7b97\u6cd5\u8bbe\u8ba1\u8303\u5f0f\u3002\u6211\u7406\u89e3\u7528\u6237\u5e0c\u671b\u83b7\u5f97\u5173\u4e8e\u52a8\u6001\u89c4\u5212\u7684\u5168\u9762\u4ecb\u7ecd\uff0c\u5305\u62ec\u6838\u5fc3\u601d\u60f3\u3001\u89e3\u9898\u65b9\u6cd5\u3001\u4ee3\u7801\u5b9e\u73b0\u548c\u5b9e\u9645\u5e94\u7528\u3002\n\n---\n\n## \u6838\u5fc3\u601d\u8def\n\n### \u7b97\u6cd5\u9009\u62e9\n\n\u52a8\u6001\u89c4\u5212\uff08Dynamic Programming, DP\uff09\u9002\u7528\u4e8e\u5177\u6709\u4ee5\u4e0b\u7279\u5f81\u7684\u95ee\u9898\uff1a\n- **\u6700\u4f18\u5b50\u7ed3\u6784**\uff1a\u95ee\u9898\u7684\u6700\u4f18\u89e3\u5305\u542b\u5b50\u95ee\u9898\u7684\u6700\u4f18\u89e3\n- **\u91cd\u53e0\u5b50\u95ee\u9898**\uff1a\u5728\u6c42\u89e3\u8fc7\u7a0b\u4e2d\uff0c\u76f8\u540c\u7684\u5b50\u95ee\u9898\u4f1a\u88ab\u91cd\u590d\u8ba1\u7b97\u591a\u6b21\n\n\u9009\u62e9\u52a8\u6001\u89c4\u5212\u7684\u539f\u56e0\u662f\u5b83\u80fd\u5c06\u6307\u6570\u7ea7\u65f6\u95f4\u590d\u6742\u5ea6\u7684\u95ee\u9898\u4f18\u5316\u5230\u591a\u9879\u5f0f\u7ea7\u522b\uff0c\u901a\u8fc7\u8bb0\u5fc6\u5316\u907f\u514d\u91cd\u590d\u8ba1\u7b97\u3002\n\n### \u5173\u952e\u6b65\u9aa4\n\n1. **\u5b9a\u4e49\u72b6\u6001**\uff1a\u786e\u5b9aDP\u6570\u7ec4\u7684\u542b\u4e49\uff0c\u901a\u5e38`dp[i]`\u8868\u793a\u5230\u7b2ci\u4e2a\u4f4d\u7f6e\u7684\u6700\u4f18\u89e3\n2. **\u627e\u51fa\u72b6\u6001\u8f6c\u79fb\u65b9\u7a0b**\uff1a\u5efa\u7acb\u5f53\u524d\u72b6\u6001\u4e0e\u4e4b\u524d\u72b6\u6001\u7684\u5173\u7cfb\n3. **\u786e\u5b9a\u521d\u59cb\u6761\u4ef6**\uff1a\u8bbe\u7f6e\u8fb9\u754c\u60c5\u51b5\u7684\u503c\n4. **\u786e\u5b9a\u8ba1\u7b97\u987a\u5e8f**\uff1a\u6309\u7167\u4f9d\u8d56\u5173\u7cfb\u4f9d\u6b21\u8ba1\u7b97\u6240\u6709\u72b6\u6001\n5. **\u8fd4\u56de\u6700\u7ec8\u7b54\u6848**\uff1a\u6839\u636e\u95ee\u9898\u8981\u6c42\u8fd4\u56de\u76f8\u5e94\u7684DP\u503c\n\n### \u76f4\u89c2\u7406\u89e3\n\n\u53ef\u4ee5\u628a\u52a8\u6001\u89c4\u5212\u60f3\u8c61\u6210**\u642d\u79ef\u6728**\uff1a\n- \u6bcf\u4e00\u5757\u79ef\u6728\uff08\u5b50\u95ee\u9898\u7684\u89e3\uff09\u90fd\u662f\u57fa\u4e8e\u4e0b\u9762\u5df2\u7ecf\u642d\u597d\u7684\u79ef\u6728\uff08\u66f4\u5c0f\u7684\u5b50\u95ee\u9898\uff09\n- \u6211\u4eec\u628a\u6bcf\u4e00\u5757\u79ef\u6728\u7684\u4f4d\u7f6e\u548c\u9ad8\u5ea6\u90fd\u8bb0\u5f55\u4e0b\u6765\uff08DP\u6570\u7ec4\uff09\n- \u8fd9\u6837\u5c31\u4e0d\u9700\u8981\u6bcf\u6b21\u90fd\u4ece\u5934\u5f00\u59cb\u91cd\u65b0\u642d\u5efa\uff08\u907f\u514d\u91cd\u590d\u8ba1\u7b97\uff09\n\n\u6216\u8005\u60f3\u8c61\u6210**\u586b\u8868\u683c**\uff1a\n- \u8868\u683c\u7684\u6bcf\u4e2a\u683c\u5b50\u4ee3\u8868\u4e00\u4e2a\u5b50\u95ee\u9898\u7684\u89e3\n- \u6211\u4eec\u6309\u7167\u4e00\u5b9a\u7684\u987a\u5e8f\u9010\u4e2a\u586b\u5199\u683c\u5b50\n- \u6bcf\u4e2a\u683c\u5b50\u7684\u503c\u53ea\u4f9d\u8d56\u4e8e\u5df2\u7ecf\u586b\u5199\u8fc7\u7684\u683c\u5b50\n\n---\n\n## \u8be6\u7ec6\u89e3\u7b54\n\n\u4e3a\u4e86\u66f4\u597d\u5730\u8bf4\u660e\u52a8\u6001\u89c4\u5212\uff0c\u6211\u4ee5\u7ecf\u5178\u7684**\u6590\u6ce2\u90a3\u5951\u6570\u5217**\u548c**\u722c\u697c\u68af\u95ee\u9898**\u4e3a\u4f8b\u8fdb\u884c\u8bb2\u89e3\u3002\n\n### \u65b9\u6cd5\u4e00\uff1a\u57fa\u7840\u89e3\u6cd5\uff08\u9012\u5f52 + \u8bb0\u5fc6\u5316\uff09\n\n**\u601d\u8def\u8bf4\u660e**\uff1a\n\u4f7f\u7528\u9012\u5f52\u65b9\u5f0f\u6c42\u89e3\uff0c\u4f46\u7528\u5b57\u5178\u6216\u6570\u7ec4\u7f13\u5b58\u5df2\u7ecf\u8ba1\u7b97\u8fc7\u7684\u7ed3\u679c\uff0c\u907f\u514d\u91cd\u590d\u8ba1\u7b97\u3002\n\n```python\ndef fibonacci_memo(n, memo={}):\n    if n in memo:\n        return memo[n]\n    if n <= 1:\n        return n\n    memo[n] = fibonacci_memo(n-1, memo) + fibonacci_memo(n-2, memo)\n    return memo[n]\n```\n\n**\u590d\u6742\u5ea6\u5206\u6790**\uff1a\n- \u65f6\u95f4\u590d\u6742\u5ea6\uff1aO(n) - \u6bcf\u4e2a\u72b6\u6001\u53ea\u8ba1\u7b97\u4e00\u6b21\n- \u7a7a\u95f4\u590d\u6742\u5ea6\uff1aO(n) - \u9012\u5f52\u6808\u6df1\u5ea6 + \u8bb0\u5fc6\u5316\u6570\u7ec4\n\n### \u65b9\u6cd5\u4e8c\uff1a\u4f18\u5316\u89e3\u6cd5\uff08\u63a8\u8350\uff09- \u81ea\u5e95\u5411\u4e0a\u8fed\u4ee3\n\n**\u4f18\u5316\u601d\u8def**\uff1a\n\u4ece\u6700\u57fa\u7840\u7684\u60c5\u51b5\u5f00\u59cb\uff0c\u9010\u6b65\u6784\u5efa\u5230\u76ee\u6807\u72b6\u6001\uff0c\u4f7f\u7528\u8fed\u4ee3\u800c\u975e\u9012\u5f52\uff0c\u8fdb\u4e00\u6b65\u4f18\u5316\u7a7a\u95f4\u3002\n\n**\u4ee3\u7801\u5b9e\u73b0**\uff1a\n\u5bf9\u4e8e\u722c\u697c\u68af\u95ee\u9898\uff08\u6bcf\u6b21\u53ef\u4ee5\u722c1\u6b65\u62162\u6b65\uff0c\u95ee\u6709\u591a\u5c11\u79cd\u65b9\u6cd5\u722c\u5230\u7b2cn\u9636\uff09\uff1a\n\n```python\ndef climb_stairs(n):\n    if n <= 2:\n        return n\n    \n    # dp[i] \u8868\u793a\u722c\u5230\u7b2ci\u9636\u7684\u65b9\u6cd5\u6570\n    dp = [0] * (n + 1)\n    dp[1] = 1\n    dp[2] = 2\n    \n    for i in range(3, n + 1):\n        dp[i] = dp[i-1] + dp[i-2]\n    \n    return dp[n]\n```\n\n**\u7a7a\u95f4\u4f18\u5316\u7248\u672c**\uff1a\n```python\ndef climb_stairs_optimized(n):\n    if n <= 2:\n        return n\n    \n    prev2, prev1 = 1, 2\n    for i in range(3, n + 1):\n        current = prev1 + prev2\n        prev2, prev1 = prev1, current\n    \n    return prev1\n```\n\n**\u590d\u6742\u5ea6\u5206\u6790**\uff1a\n- \u65f6\u95f4\u590d\u6742\u5ea6\uff1aO(n)\n- \u7a7a\u95f4\u590d\u6742\u5ea6\uff1aO(1) - \u53ea\u4f7f\u7528\u5e38\u6570\u4e2a\u53d8\u91cf\n\n---\n\n## \u4ee3\u7801\u5b9e\u73b0\n\n\u4e0b\u9762\u63d0\u4f9b\u4e00\u4e2a\u5b8c\u6574\u7684\u52a8\u6001\u89c4\u5212\u6a21\u677f\uff0c\u4ee5**\u6700\u5927\u5b50\u6570\u7ec4\u548c**\uff08Kadane\u7b97\u6cd5\uff09\u4e3a\u4f8b\uff1a\n\n```python\ndef max_subarray_sum(nums):\n    \"\"\"\n    \u52a8\u6001\u89c4\u5212\u6c42\u89e3\u6700\u5927\u5b50\u6570\u7ec4\u548c\n    dp[i] \u8868\u793a\u4ee5nums[i]\u7ed3\u5c3e\u7684\u6700\u5927\u5b50\u6570\u7ec4\u548c\n    \"\"\"\n    if not nums:\n        return 0\n    \n    n = len(nums)\n    dp = [0] * n\n    dp[0] = nums[0]\n    max_sum = dp[0]\n    \n    for i in range(1, n):\n        # \u8981\u4e48\u5355\u72ec\u53d6\u5f53\u524d\u5143\u7d20\uff0c\u8981\u4e48\u52a0\u4e0a\u524d\u9762\u7684\u5b50\u6570\u7ec4\n        dp[i] = max(nums[i], dp[i-1] + nums[i])\n        max_sum = max(max_sum, dp[i])\n    \n    return max_sum\n\ndef solution():\n    # \u793a\u4f8b\u8f93\u5165\n    print(\"\u8bf7\u8f93\u5165\u6570\u7ec4\u5143\u7d20\uff08\u7528\u7a7a\u683c\u5206\u9694\uff09:\")\n    try:\n        nums = list(map(int, input().split()))\n        result = max_subarray_sum(nums)\n        print(f\"\u6700\u5927\u5b50\u6570\u7ec4\u548c\u4e3a: {result}\")\n    except:\n        print(\"\u8f93\u5165\u683c\u5f0f\u9519\u8bef\uff0c\u8bf7\u8f93\u5165\u6574\u6570\u6570\u7ec4\")\n\nif __name__ == \"__main__\":\n    solution()\n```\n\n---\n\n## \u590d\u6742\u5ea6\u5206\u6790\n\n| \u6307\u6807 | \u590d\u6742\u5ea6 | \u8bf4\u660e |\n|------|--------|------|\n| \u65f6\u95f4\u590d\u6742\u5ea6 | O(n) | \u9700\u8981\u904d\u5386\u6570\u7ec4\u4e00\u6b21\uff0c\u6bcf\u4e2a\u72b6\u6001\u8ba1\u7b97\u65f6\u95f4\u4e3aO(1) |\n| \u7a7a\u95f4\u590d\u6742\u5ea6 | O(n) | \u4f7f\u7528\u4e86\u957f\u5ea6\u4e3an\u7684DP\u6570\u7ec4\u5b58\u50a8\u4e2d\u95f4\u7ed3\u679c |\n\n> \u6ce8\uff1a\u5982\u679c\u4f7f\u7528\u7a7a\u95f4\u4f18\u5316\u7248\u672c\uff0c\u7a7a\u95f4\u590d\u6742\u5ea6\u53ef\u964d\u81f3O(1)\n\n---\n\n## \u76f8\u5173\u62d3\u5c55\n\n### \u7c7b\u4f3c\u9898\u76ee\n1. **\u7ecf\u5178DP\u95ee\u9898**\uff1a\n   - \u80cc\u5305\u95ee\u9898\uff080-1\u80cc\u5305\u3001\u5b8c\u5168\u80cc\u5305\uff09\n   - \u6700\u957f\u516c\u5171\u5b50\u5e8f\u5217\uff08LCS\uff09\n   - \u6700\u957f\u9012\u589e\u5b50\u5e8f\u5217\uff08LIS\uff09\n   - \u7f16\u8f91\u8ddd\u79bb\n   - \u4e0d\u540c\u8def\u5f84\n\n2. 