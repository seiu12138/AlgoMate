[{"type": "human", "data": {"content": "\u52a8\u6001\u89c4\u5212", "additional_kwargs": {}, "response_metadata": {}, "type": "human", "name": null, "id": null}}, {"type": "ai", "data": {"content": "# \u52a8\u6001\u89c4\u5212\u8be6\u89e3\n\n## \u95ee\u9898\u7406\u89e3\n\u7528\u6237\u5e0c\u671b\u4e86\u89e3\u52a8\u6001\u89c4\u5212\uff08Dynamic Programming, DP\uff09\u8fd9\u4e00\u7b97\u6cd5\u601d\u60f3\u3002\u52a8\u6001\u89c4\u5212\u662f\u7b97\u6cd5\u7ade\u8d5b\u548c\u5b9e\u9645\u7f16\u7a0b\u4e2d\u6700\u91cd\u8981\u3001\u6700\u5e38\u7528\u7684\u7b97\u6cd5\u8303\u5f0f\u4e4b\u4e00\uff0c\u7528\u4e8e\u9ad8\u6548\u89e3\u51b3\u5177\u6709**\u6700\u4f18\u5b50\u7ed3\u6784**\u548c**\u91cd\u53e0\u5b50\u95ee\u9898**\u6027\u8d28\u7684\u95ee\u9898\u3002\n\n---\n\n## \u6838\u5fc3\u601d\u8def\n\n### \u7b97\u6cd5\u9009\u62e9\n- **\u4e3a\u4ec0\u4e48\u9009\u62e9\u52a8\u6001\u89c4\u5212**\uff1a\u5f53\u95ee\u9898\u53ef\u4ee5\u5206\u89e3\u4e3a\u76f8\u4e92\u91cd\u53e0\u7684\u5b50\u95ee\u9898\uff0c\u4e14\u5b50\u95ee\u9898\u7684\u6700\u4f18\u89e3\u80fd\u6784\u6210\u539f\u95ee\u9898\u7684\u6700\u4f18\u89e3\u65f6\uff0c\u4f7f\u7528DP\u53ef\u4ee5\u907f\u514d\u91cd\u590d\u8ba1\u7b97\uff0c\u663e\u8457\u63d0\u9ad8\u6548\u7387\u3002\n- **\u6838\u5fc3\u601d\u60f3**\uff1a\u5c06\u590d\u6742\u95ee\u9898\u5206\u89e3\u4e3a\u66f4\u5c0f\u7684\u5b50\u95ee\u9898\uff0c\u901a\u8fc7\u5b58\u50a8\u5b50\u95ee\u9898\u7684\u89e3\uff08\u8bb0\u5fc6\u5316\uff09\u6765\u907f\u514d\u91cd\u590d\u8ba1\u7b97\uff0c\u6700\u7ec8\u6784\u5efa\u51fa\u539f\u95ee\u9898\u7684\u89e3\u3002\n\n### \u5173\u952e\u6b65\u9aa4\n1. **\u5b9a\u4e49\u72b6\u6001**\uff1a\u786e\u5b9aDP\u6570\u7ec4\uff08\u6216\u51fd\u6570\uff09\u7684\u542b\u4e49\uff0c\u5373`dp[i]`\u6216`dp[i][j]`\u4ee3\u8868\u4ec0\u4e48\n2. **\u627e\u51fa\u72b6\u6001\u8f6c\u79fb\u65b9\u7a0b**\uff1a\u786e\u5b9a\u5982\u4f55\u4ece\u5df2\u77e5\u72b6\u6001\u63a8\u5bfc\u51fa\u65b0\u72b6\u6001\n3. **\u786e\u5b9a\u521d\u59cb\u6761\u4ef6**\uff1a\u8bbe\u7f6e\u8fb9\u754c\u60c5\u51b5\u7684\u57fa\u7840\u503c\n4. **\u786e\u5b9a\u8ba1\u7b97\u987a\u5e8f**\uff1a\u6309\u7167\u4f9d\u8d56\u5173\u7cfb\u6b63\u786e\u8ba1\u7b97\u5404\u4e2a\u72b6\u6001\n5. **\u8fd4\u56de\u6700\u7ec8\u7b54\u6848**\uff1a\u6839\u636e\u95ee\u9898\u8981\u6c42\u8fd4\u56de\u76f8\u5e94\u7684DP\u503c\n\n### \u76f4\u89c2\u7406\u89e3\n\u53ef\u4ee5\u628a\u52a8\u6001\u89c4\u5212\u60f3\u8c61\u6210**\u642d\u79ef\u6728**\uff1a\n- \u6bcf\u4e2a\u79ef\u6728\u4ee3\u8868\u4e00\u4e2a\u5b50\u95ee\u9898\u7684\u89e3\n- \u6211\u4eec\u6309\u7167\u4e00\u5b9a\u7684\u89c4\u5219\uff08\u72b6\u6001\u8f6c\u79fb\u65b9\u7a0b\uff09\u628a\u5c0f\u79ef\u6728\u642d\u6210\u5927\u79ef\u6728\n- \u6700\u7ec8\u642d\u6210\u6211\u4eec\u9700\u8981\u7684\u5927\u7ed3\u6784\uff08\u539f\u95ee\u9898\u7684\u89e3\uff09\n- \u5173\u952e\u662f\u6bcf\u4e2a\u79ef\u6728\u53ea\u505a\u4e00\u6b21\uff0c\u505a\u597d\u540e\u53ef\u4ee5\u91cd\u590d\u4f7f\u7528\n\n---\n\n## \u8be6\u7ec6\u89e3\u7b54\n\n\u4e3a\u4e86\u5177\u4f53\u8bf4\u660e\uff0c\u6211\u4eec\u4ee5\u7ecf\u5178\u7684**\u6590\u6ce2\u90a3\u5951\u6570\u5217**\u4e3a\u4f8b\uff1a\n\n### \u65b9\u6cd5\u4e00\uff1a\u57fa\u7840\u89e3\u6cd5\uff08\u9012\u5f52 + \u8bb0\u5fc6\u5316\uff09\n\n**\u601d\u8def\u8bf4\u660e**\uff1a\n- \u4f7f\u7528\u9012\u5f52\u76f4\u63a5\u5b9e\u73b0\u72b6\u6001\u8f6c\u79fb\u65b9\u7a0b\n- \u7528\u5b57\u5178\u6216\u6570\u7ec4\u5b58\u50a8\u5df2\u8ba1\u7b97\u7684\u7ed3\u679c\uff0c\u907f\u514d\u91cd\u590d\u8ba1\u7b97\n\n```python\ndef fib_memo(n, memo):\n    if n <= 1:\n        return n\n    if memo[n] != -1:\n        return memo[n]\n    memo[n] = fib_memo(n-1, memo) + fib_memo(n-2, memo)\n    return memo[n]\n\ndef fibonacci_memo(n):\n    memo = [-1] * (n + 1)\n    return fib_memo(n, memo)\n```\n\n**\u590d\u6742\u5ea6\u5206\u6790**\uff1a\n- \u65f6\u95f4\u590d\u6742\u5ea6\uff1aO(n) - \u6bcf\u4e2a\u72b6\u6001\u53ea\u8ba1\u7b97\u4e00\u6b21\n- \u7a7a\u95f4\u590d\u6742\u5ea6\uff1aO(n) - \u5b58\u50a8memo\u6570\u7ec4\u548c\u9012\u5f52\u6808\n\n### \u65b9\u6cd5\u4e8c\uff1a\u4f18\u5316\u89e3\u6cd5\uff08\u63a8\u8350\uff09- \u8fed\u4ee3DP\n\n**\u4f18\u5316\u601d\u8def**\uff1a\n- \u81ea\u5e95\u5411\u4e0a\u8ba1\u7b97\uff0c\u907f\u514d\u9012\u5f52\u5f00\u9500\n- \u89c2\u5bdf\u5230\u53ea\u9700\u8981\u524d\u4e24\u4e2a\u72b6\u6001\uff0c\u53ef\u4ee5\u8fdb\u4e00\u6b65\u7a7a\u95f4\u4f18\u5316\n\n**\u4ee3\u7801\u5b9e\u73b0**\uff1a\n```python\ndef fibonacci_dp(n):\n    if n <= 1:\n        return n\n    \n    # \u53ea\u9700\u8981\u4fdd\u5b58\u524d\u4e24\u4e2a\u503c\n    prev2, prev1 = 0, 1\n    for i in range(2, n + 1):\n        current = prev1 + prev2\n        prev2, prev1 = prev1, current\n    \n    return prev1\n```\n\n**\u590d\u6742\u5ea6\u5206\u6790**\uff1a\n- \u65f6\u95f4\u590d\u6742\u5ea6\uff1aO(n)\n- \u7a7a\u95f4\u590d\u6742\u5ea6\uff1aO(1) - \u7a7a\u95f4\u4f18\u5316\u7248\u672c\n\n---\n\n## \u4ee3\u7801\u5b9e\u73b0\n\n\u4e0b\u9762\u63d0\u4f9b\u4e00\u4e2a\u901a\u7528\u7684\u52a8\u6001\u89c4\u5212\u6a21\u677f\uff0c\u4ee5**\u722c\u697c\u68af\u95ee\u9898**\u4e3a\u4f8b\uff08\u6bcf\u6b21\u53ef\u4ee5\u722c1\u62162\u9636\uff0c\u95ee\u6709\u591a\u5c11\u79cd\u65b9\u6cd5\u722c\u5230\u7b2cn\u9636\uff09\uff1a\n\n```python\ndef solution():\n    # \u8bfb\u53d6\u8f93\u5165\n    n = int(input().strip())\n    \n    # \u5904\u7406\u8fb9\u754c\u60c5\u51b5\n    if n <= 2:\n        print(n)\n        return\n    \n    # DP\u6570\u7ec4\uff0cdp[i]\u8868\u793a\u722c\u5230\u7b2ci\u9636\u7684\u65b9\u6cd5\u6570\n    dp = [0] * (n + 1)\n    dp[1] = 1\n    dp[2] = 2\n    \n    # \u72b6\u6001\u8f6c\u79fb\uff1adp[i] = dp[i-1] + dp[i-2]\n    for i in range(3, n + 1):\n        dp[i] = dp[i-1] + dp[i-2]\n    \n    print(dp[n])\n\nif __name__ == \"__main__\":\n    solution()\n```\n\n\u5982\u679c\u9700\u8981\u7a7a\u95f4\u4f18\u5316\u7248\u672c\uff1a\n\n```python\ndef solution_optimized():\n    n = int(input().strip())\n    \n    if n <= 2:\n        print(n)\n        return\n    \n    # \u53ea\u4fdd\u5b58\u524d\u4e24\u4e2a\u72b6\u6001\n    prev2, prev1 = 1, 2\n    for i in range(3, n + 1):\n        curr