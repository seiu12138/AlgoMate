b\u5982\uff1a`nums = [2, 7, 11, 15]`, `target = 9` \u2192 \u8fd4\u56de `[0, 1]`\uff0c\u56e0\u4e3a `nums[0] + nums[1] = 2 + 7 = 9`\u3002\n\n---\n\n## \u6838\u5fc3\u601d\u8def\n\n### \u7b97\u6cd5\u9009\u62e9\n\n- **\u4e3a\u4ec0\u4e48\u9009\u62e9\u54c8\u5e0c\u8868**\uff1a\u66b4\u529b\u89e3\u6cd5\u9700\u8981 O(n\u00b2) \u65f6\u95f4\uff0c\u800c\u4f7f\u7528\u54c8\u5e0c\u8868\u53ef\u4ee5\u5728\u4e00\u6b21\u904d\u5386\u4e2d\u5b8c\u6210\u67e5\u627e\uff0c\u5c06\u65f6\u95f4\u590d\u6742\u5ea6\u4f18\u5316\u5230 O(n)\n- **\u6838\u5fc3\u601d\u60f3**\uff1a\u5bf9\u4e8e\u6bcf\u4e2a\u5143\u7d20 `nums[i]`\uff0c\u6211\u4eec\u60f3\u77e5\u9053\u662f\u5426\u5b58\u5728\u4e00\u4e2a\u5143\u7d20 `nums[j]`\uff08j < i\uff09\uff0c\u4f7f\u5f97 `nums[j] = target - nums[i]`\u3002\u901a\u8fc7\u54c8\u5e0c\u8868\u5b58\u50a8\u5df2\u904d\u5386\u5143\u7d20\u7684\u503c\u548c\u7d22\u5f15\uff0c\u53ef\u4ee5\u5b9e\u73b0 O(1) \u7684\u67e5\u627e\n\n### \u5173\u952e\u6b65\u9aa4\n\n1. **\u521d\u59cb\u5316\u54c8\u5e0c\u8868**\uff1a\u521b\u5efa\u4e00\u4e2a\u7a7a\u5b57\u5178\u7528\u4e8e\u5b58\u50a8\u6570\u503c\u5230\u7d22\u5f15\u7684\u6620\u5c04\n2. **\u904d\u5386\u6570\u7ec4**\uff1a\u5bf9\u6bcf\u4e2a\u5143\u7d20 `nums[i]`\uff1a\n   - \u8ba1\u7b97\u8865\u6570 `complement = target - nums[i]`\n   - \u68c0\u67e5\u8865\u6570\u662f\u5426\u5df2\u5728\u54c8\u5e0c\u8868\u4e2d\n   - \u5982\u679c\u5b58\u5728\uff0c\u8fd4\u56de\u5f53\u524d\u7d22\u5f15\u548c\u8865\u6570\u7684\u7d22\u5f15\n   - \u5982\u679c\u4e0d\u5b58\u5728\uff0c\u5c06\u5f53\u524d\u5143\u7d20\u548c\u7d22\u5f15\u5b58\u5165\u54c8\u5e0c\u8868\n3. **\u8fd4\u56de\u7ed3\u679c**\uff1a\u627e\u5230\u7b54\u6848\u540e\u7acb\u5373\u8fd4\u56de\uff0c\u9898\u76ee\u4fdd\u8bc1\u6709\u552f\u4e00\u89e3\n\n### \u76f4\u89c2\u7406\u89e3\n\n\u60f3\u8c61\u4f60\u5728\u627e\u62fc\u56fe\u7684\u53e6\u4e00\u534a\u3002\u4f60\u624b\u91cc\u62ff\u7740\u4e00\u5757\u62fc\u56fe\uff08\u5f53\u524d\u6570\u5b57\uff09\uff0c\u4f60\u9700\u8981\u627e\u4e00\u5757\u80fd\u548c\u5b83\u5b8c\u7f8e\u62fc\u63a5\u7684\uff08\u8865\u6570 = target - \u5f53\u524d\u6570\u5b57\uff09\u3002\u4f60\u6709\u4e00\u4e2a\u7b14\u8bb0\u672c\uff08\u54c8\u5e0c\u8868\uff09\uff0c\u8bb0\u5f55\u4e86\u4e4b\u524d\u89c1\u8fc7\u7684\u6240\u6709\u62fc\u56fe\u5757\u548c\u5b83\u4eec\u7684\u4f4d\u7f6e\u3002\u6bcf\u6b21\u62ff\u5230\u65b0\u62fc\u56fe\u65f6\uff0c\u5148\u67e5\u7b14\u8bb0\u672c\u770b\u6709\u6ca1\u6709\u5339\u914d\u7684\uff0c\u5982\u679c\u6ca1\u6709\u5c31\u628a\u8fd9\u5757\u4e5f\u8bb0\u4e0b\u6765\u3002\n\n---\n\n## \u8be6\u7ec6\u89e3\u7b54\n\n### \u65b9\u6cd5\u4e00\uff1a\u57fa\u7840\u89e3\u6cd5\uff08\u66b4\u529b\u679a\u4e3e\uff09\n\n**\u601d\u8def\u8bf4\u660e**\uff1a\n\u4f7f\u7528\u4e24\u5c42\u5d4c\u5957\u5faa\u73af\uff0c\u5bf9\u6bcf\u4e00\u5bf9\u6570\u5b57\u68c0\u67e5\u5b83\u4eec\u7684\u548c\u662f\u5426\u7b49\u4e8e\u76ee\u6807\u503c\u3002\n\n**\u4ee3\u7801\u5b9e\u73b0**\uff1a\n```python\ndef two_sum_brute_force(nums, target):\n    n = len(nums)\n    for i in range(n):\n        for j in range(i + 1, n):\n            if nums[i] + nums[j] == target:\n                return [i, j]\n    return []  # \u9898\u76ee\u4fdd\u8bc1\u6709\u89e3\uff0c\u8fd9\u884c\u7406\u8bba\u4e0a\u4e0d\u4f1a\u6267\u884c\n```\n\n**\u590d\u6742\u5ea6\u5206\u6790**\uff1a\n- \u65f6\u95f4\u590d\u6742\u5ea6\uff1aO(n\u00b2)\uff0c\u9700\u8981\u68c0\u67e5\u6240\u6709\u53ef\u80fd\u7684\u6570\u5b57\u5bf9\n- \u7a7a\u95f4\u590d\u6742\u5ea6\uff1aO(1)\uff0c\u53ea\u4f7f\u7528\u5e38\u6570\u989d\u5916\u7a7a\u95f4\n\n### \u65b9\u6cd5\u4e8c\uff1a\u4f18\u5316\u89e3\u6cd5\uff08\u63a8\u8350\uff09\n\n**\u4f18\u5316\u601d\u8def**\uff1a\n\u4f7f\u7528\u54c8\u5e0c\u8868\uff08\u5b57\u5178\uff09\u5728\u4e00\u6b21\u904d\u5386\u4e2d\u540c\u65f6\u8fdb\u884c\u67e5\u627e\u548c\u5b58\u50a8\uff0c\u907f\u514d\u91cd\u590d\u8ba1\u7b97\u3002\n\n**\u4ee3\u7801\u5b9e\u73b0**\uff1a\n```python\ndef two_sum_optimized(nums, target):\n    num_to_index = {}  # \u54c8\u5e0c\u8868\uff1a\u6570\u503c -> \u7d22\u5f15\n    \n    for i, num in enumerate(nums):\n        complement