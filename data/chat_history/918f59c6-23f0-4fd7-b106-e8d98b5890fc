u9009\u62e9\u2014\u2014\u62a2\u6216\u4e0d\u62a2\uff0c\u9009\u62e9\u80fd\u5e26\u6765\u66f4\u5927\u6536\u76ca\u7684\u65b9\u6848\n\n### \u5173\u952e\u6b65\u9aa4\n1. **\u5b9a\u4e49\u72b6\u6001**\uff1a`dp[i]` \u8868\u793a\u62a2\u52ab\u524di\u4e2a\u623f\u5c4b\u80fd\u83b7\u5f97\u7684\u6700\u5927\u91d1\u989d\n2. **\u72b6\u6001\u8f6c\u79fb\u65b9\u7a0b**\uff1a`dp[i] = max(dp[i-1], dp[i-2] + nums[i-1])`\n   - `dp[i-1]`\uff1a\u4e0d\u62a2\u7b2ci\u4e2a\u623f\u5c4b\n   - `dp[i-2] + nums[i-1]`\uff1a\u62a2\u7b2ci\u4e2a\u623f\u5c4b\uff08\u6ce8\u610f\u6570\u7ec4\u7d22\u5f15\u4ece0\u5f00\u59cb\uff09\n3. **\u521d\u59cb\u6761\u4ef6**\uff1a`dp[0] = 0`, `dp[1] = nums[0]`\n4. **\u8ba1\u7b97\u987a\u5e8f**\uff1a\u4ece\u5de6\u5230\u53f3\u4f9d\u6b21\u8ba1\u7b97\n5. **\u8fd4\u56de\u7ed3\u679c**\uff1a`dp[n]`\uff08n\u4e3a\u623f\u5c4b\u6570\u91cf\uff09\n\n### \u76f4\u89c2\u7406\u89e3\n\n\u53ef\u4ee5\u628a\u8fd9\u4e2a\u95ee\u9898\u60f3\u8c61\u6210**\u8d70\u697c\u68af\u6361\u91d1\u5e01**\uff1a\n- \u6bcf\u4e2a\u53f0\u9636\u4e0a\u6709\u4e00\u4e2a\u91d1\u5e01\uff08\u623f\u5c4b\u91cc\u7684\u94b1\uff09\n- \u4f60\u4e0d\u80fd\u8fde\u7eed\u8e29\u4e24\u4e2a\u76f8\u90bb\u7684\u53f0\u9636\n- \u95ee\u6700\u591a\u80fd\u6361\u5230\u591a\u5c11\u91d1\u5e01\n\n\u6216\u8005\u7528**\u51b3\u7b56\u6811**\u6765\u7406\u89e3\uff1a\n- \u5728\u6bcf\u4e2a\u623f\u5c4b\u9762\u524d\uff0c\u4f60\u90fd\u8981\u505a\u51b3\u5b9a\uff1a\u62a2\u8fd8\u662f\u4e0d\u62a2\uff1f\n- \u5982\u679c\u62a2\u4e86\u5f53\u524d\u623f\u5c4b\uff0c\u5c31\u4e0d\u80fd\u62a2\u4e0b\u4e00\u4e2a\n- \u5982\u679c\u4e0d\u62a2\u5f53\u524d\u623f\u5c4b\uff0c\u53ef\u4ee5\u8003\u8651\u62a2\u4e0b\u4e00\u4e2a\n- \u52a8\u6001\u89c4\u5212\u5e2e\u6211\u4eec\u8bb0\u5f55\u6bcf\u4e00\u6b65\u7684\u6700\u4f18\u9009\u62e9\n\n---\n\n## \u8be6\u7ec6\u89e3\u7b54\n\n### \u65b9\u6cd5\u4e00\uff1a\u57fa\u7840\u89e3\u6cd5\uff08\u6570\u7ec4DP\uff09\n\n**\u601d\u8def\u8bf4\u660e**\uff1a\n\u4f7f\u7528\u4e00\u7ef4\u6570\u7ec4 `dp` \u6765\u5b58\u50a8\u6bcf\u4e2a\u72b6\u6001\u7684\u6700\u4f18\u89e3\u3002`dp[i]` \u8868\u793a\u8003\u8651\u524di\u4e2a\u623f\u5c4b\u65f6\u7684\u6700\u5927\u6536\u76ca\u3002\n\n```python\ndef rob_basic(nums):\n    if not nums:\n        return 0\n    if len(nums) == 1:\n        return nums[0]\n    \n    n = len(nums)\n    dp = [0] * (n + 1)\n    dp[0] = 0\n    dp[1] = nums[0]\n    \n    for i in range(2, n + 1):\n        # \u4e0d\u62a2\u7b2ci\u4e2a\u623f\u5c4b vs \u62a2\u7b2ci\u4e2a\u623f\u5c4b\n        dp[i] = max(dp[i-1], dp[i-2] + nums[i-1])\n    \n    return dp[n]\n```\n\n**\u590d\u6742\u5ea6\u5206\u6790**\uff1a\n- \u65f6\u95f4\u590d\u6742\u5ea6\uff1aO(n) - \u904d\u5386\u4e00\u6b21\u6570\u7ec4\n- \u7a7a\u95f4\u590d\u6742\u5ea6\uff1aO(n) - \u4f7f\u7528\u4e86\u957f\u5ea6\u4e3an+1\u7684dp\u6570\u7ec4\n\n### \u65b9\u6cd5\u4e8c\uff1a\u4f18\u5316\u89e3\u6cd5\uff08\u63a8\u8350\uff09- \u7a7a\u95f4\u4f18\u5316\n\n**\u4f18\u5316\u601d\u8def**\uff1a\n\u89c2\u5bdf\u72b6\u6001\u8f6c\u79fb\u65b9\u7a0b `dp[i] = max(dp[i-1], dp[i-2] + nums[i-1])`\uff0c\u53d1\u73b0\u5f53\u524d\u72b6\u6001\u53ea\u4f9d\u8d56\u4e8e\u524d\u4e24\u4e2a\u72b6\u6001\u3002\u56e0\u6b64\u53ef\u4ee5\u7528\u4e24\u4e2a\u53d8\u91cf\u4ee3\u66ff\u6574\u4e2adp\u6570\u7ec4\uff0c\u5c06\u7a7a\u95f4\u590d\u6742\u5ea6\u4f18\u5316\u5230O(1)\u3002\n\n**\u4ee3\u7801\u5b9e\u73b0**\uff1a\n```python\ndef rob_optimized(nums):\n    if not nums:\n        return 0\n    if len(nums) == 1:\n        return nums[0]\n    \n    # prev2: dp[i-2], prev1: dp[i-1]\n    prev2, prev1 = 0, nums[0]\n    \n    for i in range(1, len(nums)):\n        current = max(prev1, prev2 + nums[i])\n        prev2, prev1 = prev1, current\n    \n    return prev1\n```\n\n**\u590d\u6742\u5ea6\u5206\u6790**\uff1a\n- \u65f6\u95f4\u590d\u6742\u5ea6\uff1aO(n) - \u4ecd\u7136\u9700\u8981\u904d\u5386\u6240\u6709\u623f\u5c4b\n- \u7a7a\u95f4\u590d\u6742\u5ea6\uff1aO(1) - \u53ea\u4f7f\u7528\u4e86\u5e38\u6570\u4e2a\u989d\u5916\u53d8\u91cf\n\n---\n\n## \u4ee3\u7801\u5b9e\u73b0\n\n```python\ndef solution():\n    # \u8bfb\u53d6\u8f93\u5165\uff1a\u4e00\u884c\u6570\u5b57\uff0c\u7528\u7a7a\u683c\u5206\u9694\n    try:\n        nums = list(map(int, input().strip().split()))\n    except:\n        nums = []\n    \n    # \u5904\u7406\u8fb9\u754c\u60c5\u51b5\n    if not nums:\n        print(0)\n        return\n    if len(nums) == 1:\n        print(nums[0])\n        return\n    \n    # \u52a8\u6001\u89c4\u5212\u6c42\u89e3\uff08\u7a7a\u95f4\u4f18\u5316\u7248\u672c\uff09\n    prev2, prev1 = 0, nums[0]\n    \n    for i in range(1, len(nums)):\n        current = max(prev1, prev2 + nums[i])\n        prev2, prev1 = prev1, current\n    \n    print(prev1)\n\nif __name__ == \"__main__\":\n    solution()\n```\n\n---\n\n## \u590d\u6742\u5ea6\u5206\u6790\n\n| \u6307\u6807 | \u590d\u6742\u5ea6 | \u8bf4\u660e |\n|------|--------|------|\n| \u65f6\u95f4\u590d\u6742\u5ea6 | O(n) | \u9700\u8981\u904d\u5386\u6240\u6709n\u4e2a\u623f\u5c4b\uff0c\u6bcf\u4e2a\u623f\u5c4b\u5904\u7406\u65f6\u95f4\u4e3aO(1) |\n| \u7a7a\u95f4\u590d\u6742\u5ea6 | O(1) | \u53ea\u4f7f\u7528\u4e86prev2\u3001prev1\u3001current\u4e09\u4e2a\u53d8\u91cf\u5b58\u50a8\u72b6\u6001 |\n\n---\n\n## \u76f8\u5173\u62d3\u5c55\n\n### \u7c7b\u4f3c\u9898\u76ee\n- **\u6253\u5bb6\u52ab\u820d II**\uff1a\u623f\u5c4b\u6392\u5217\u6210\u73af\u5f62\uff0c\u9996\u5c3e\u76f8\u90bb\n- **\u6253\u5bb6\u52ab\u820d III**\uff1a\u623f\u5c4b\u6392\u5217\u6210\u4e8c\u53c9\u6811\u7ed3\u6784\n- **\u80a1\u7968\u4e70\u5356\u95ee\u9898**\uff1a\u7c7b\u4f3c\u7684\u51b3\u7b56\u578b\u52a8\u6001\u89c4\u5212\u95ee\u9898\n- **\u6700\u5927\u5b50\u6570\u7ec4\u548c**\uff1aKadane\u7b97\u6cd5\uff0c\u4e5f\u662f\u7ebf\u6027DP\u7684\u7ecf\u5178\u5e94\u7528\n- **\u8df3\u8dc3\u6e38\u620f**\uff1a\u6d89\u53ca\u53ef\u8fbe\u6027\u548c\u6700\u4f18\u8def\u5f84\u7684\u9009\u62e9\n\n### \u8fdb\u9636\u77e5\u8bc6\n- **\u73af\u5f62DP**\uff1a\u5904\u7406\u9996\u5c3e\u76f8\u8fde\u7684\u60c5\u51b5\uff0c\u901a\u5e38\u9700\u8981\u5206\u522b\u8ba1\u7b97\u5305\u542b\u9996\u5143\u7d20\u548c\u5305\u542b\u5c3e\u5143\u7d20\u7684\u4e24\u79cd\u60c5\u51b5\n- **\u6811\u5f62DP**\uff1a\u5728\u6811\u7ed3\u6784\u4e0a\u8fdb\u884c\u52a8\u6001\u89c4\u5212\uff0c\u9700\u8981\u540e\u5e8f\u904d\u5386\u6765\u786e\u4fdd\u5b50\u95ee\u9898\u5148\u88ab\u89e3\u51b3\n- **\u72b6\u6001\u673aDP**\uff1a\u5c06\u95ee\u9898\u5efa\u6a21\u4e3a\u72b6\u6001\u8f6c\u79fb\uff0c\u5982\u80a1\u7968\u95ee\u9898\u4e2d\u7684\u6301\u6709/\u4e0d\u6301\u6709\u72b6\u6001\n- **\u6eda\u52a8\u6570\u7ec4**\uff1a\u901a\u7528\u7684\u7a7a\u95f4\u4f18\u5316\u6280\u5de7\uff0c\u9002\u7528\u4e8e\u72b6\u6001\u53ea\u4f9d\u8d56\u4e8e\u56fa\u5b9a\u6570\u91cf\u524d\u9a71\u72b6\u6001\u7684\u95ee\u9898\n\n### \u5e38\u89c1\u9519\u8bef\n1. **\u8fb9\u754c\u6761\u4ef6\u5904\u7406\u4e0d\u5f53**\uff1a\n   - \u5fd8\u8bb0\u5904\u7406\u7a7a\u6570\u7ec4\u6216\u5355\u5143\u7d20\u6570\u7ec4\u7684\u60c5\u51b5\n   - **\u907f\u514d\u65b9\u6cd5**\uff1a\u5728\u5f00\u59cb\u5c31\u5904\u7406\u7279\u6b8a\u60c5\u51b5\n\n2. **\u72b6\u6001\u8f6c\u79fb\u65b9\u7a0b\u9519\u8bef**\uff1a\n   - \u9519\u8bef\u5730\u8ba4\u4e3a\u5fc5\u987b\u62a2\u67d0\u4e2a\u623f\u5c4b\uff0c\u6216\u8005\u5ffd\u7565\u4e86\u76f8\u90bb\u7ea6\u675f\n   - **\u907f\u514d\u65b9\u6cd5**\uff1a\u624b\u52a8\u9a8c\u8bc1\u5c0f\u4f8b\u5b50\uff0c\u5982 `[2,1,1,2]` \u5e94\u8be5\u8fd4\u56de4\n\n3. **\u6570\u7ec4\u7d22\u5f15\u6df7\u6dc6**\uff1a\n   - \u5728dp\u6570\u7ec4\u548c\u539f\u6570\u7ec4\u4e4b\u95f4\u7d22\u5f15\u5bf9\u5e94\u5173\u7cfb\u51fa\u9519\n   - **\u907f\u514d\u65b9\u6cd5**\uff1a\u660e\u786e `dp[i]` \u5bf9\u5e94 `nums[0...i-1]`\n\n4. **\u7a7a\u95f4\u4f18\u5316\u65f6\u53d8\u91cf\u66f4\u65b0\u987a\u5e8f\u9519\u8bef**\uff1a\n   - \u5148\u66f4\u65b0\u4e86prev2\u518d\u66f4\u65b0prev1\uff0c\u5bfc\u81f4\u4f7f\u7528\u4e86\u9519\u8bef\u7684\u503c\n   - **\u907f\u514d\u65b9\u6cd5**\uff1a\u540c\u65f6\u66f4\u65b0\u6216\u4f7f\u7528\u4e34\u65f6\u53d8\u91cf\n\n5. **\u8d2a\u5fc3\u7b56\u7565\u8bef\u533a**\uff1a\n   - \u8bd5\u56fe\u6bcf\u6b21\u90fd\u9009\u62e9\u8f83\u5927\u7684\u76f8\u90bb\u5143\u7d20\uff0c\u4f46\u8fd9\u4e0d\u