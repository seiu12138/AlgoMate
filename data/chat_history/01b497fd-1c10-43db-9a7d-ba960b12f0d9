[{"type": "human", "data": {"content": "\u52a8\u6001\u89c4\u5212", "additional_kwargs": {}, "response_metadata": {}, "type": "human", "name": null, "id": null}}, {"type": "ai", "data": {"content": "# \u52a8\u6001\u89c4\u5212\u8be6\u89e3\n\n## \u95ee\u9898\u7406\u89e3\n\u7528\u6237\u8be2\u95ee\u7684\u662f**\u52a8\u6001\u89c4\u5212\uff08Dynamic Programming, DP\uff09**\u8fd9\u4e00\u7b97\u6cd5\u601d\u60f3\u3002\u52a8\u6001\u89c4\u5212\u662f\u7b97\u6cd5\u7ade\u8d5b\u548c\u5b9e\u9645\u7f16\u7a0b\u4e2d\u975e\u5e38\u91cd\u8981\u7684\u6280\u672f\uff0c\u7528\u4e8e\u89e3\u51b3\u5177\u6709**\u91cd\u53e0\u5b50\u95ee\u9898**\u548c**\u6700\u4f18\u5b50\u7ed3\u6784**\u6027\u8d28\u7684\u95ee\u9898\u3002\n\n---\n\n## \u6838\u5fc3\u601d\u8def\n\n### \u7b97\u6cd5\u9009\u62e9\n- **\u4e3a\u4ec0\u4e48\u9009\u62e9\u52a8\u6001\u89c4\u5212**\uff1a\u5f53\u95ee\u9898\u53ef\u4ee5\u5206\u89e3\u4e3a\u76f8\u4e92\u91cd\u53e0\u7684\u5b50\u95ee\u9898\uff0c\u4e14\u539f\u95ee\u9898\u7684\u6700\u4f18\u89e3\u5305\u542b\u5b50\u95ee\u9898\u7684\u6700\u4f18\u89e3\u65f6\uff0c\u52a8\u6001\u89c4\u5212\u80fd\u907f\u514d\u91cd\u590d\u8ba1\u7b97\uff0c\u663e\u8457\u63d0\u9ad8\u6548\u7387\u3002\n- **\u6838\u5fc3\u601d\u60f3**\uff1a\u5c06\u590d\u6742\u95ee\u9898\u5206\u89e3\u4e3a\u66f4\u5c0f\u7684\u5b50\u95ee\u9898\uff0c\u5b58\u50a8\u5b50\u95ee\u9898\u7684\u89e3\uff08\u8bb0\u5fc6\u5316\uff09\uff0c\u901a\u8fc7\u7ec4\u5408\u5b50\u95ee\u9898\u7684\u89e3\u6765\u6784\u5efa\u539f\u95ee\u9898\u7684\u89e3\u3002\n\n### \u5173\u952e\u6b65\u9aa4\n1. **\u5b9a\u4e49\u72b6\u6001**\uff1a\u786e\u5b9aDP\u6570\u7ec4\u7684\u542b\u4e49\uff0c\u5373`dp[i]`\u6216`dp[i][j]`\u4ee3\u8868\u4ec0\u4e48\n2. **\u627e\u51fa\u72b6\u6001\u8f6c\u79fb\u65b9\u7a0b**\uff1a\u5efa\u7acb\u5f53\u524d\u72b6\u6001\u4e0e\u4e4b\u524d\u72b6\u6001\u7684\u5173\u7cfb\n3. **\u786e\u5b9a\u521d\u59cb\u6761\u4ef6**\uff1a\u8bbe\u7f6e\u8fb9\u754c\u60c5\u51b5\u7684\u503c\n4. **\u786e\u5b9a\u8ba1\u7b97\u987a\u5e8f**\uff1a\u6309\u7167\u4f9d\u8d56\u5173\u7cfb\u4f9d\u6b21\u8ba1\u7b97\u6240\u6709\u72b6\u6001\n5. **\u8fd4\u56de\u6700\u7ec8\u7b54\u6848**\uff1a\u4eceDP\u6570\u7ec4\u4e2d\u63d0\u53d6\u6240\u9700\u7ed3\u679c\n\n### \u76f4\u89c2\u7406\u89e3\n\u53ef\u4ee5\u628a\u52a8\u6001\u89c4\u5212\u60f3\u8c61\u6210**\u722c\u697c\u68af**\uff1a\n- \u6bcf\u4e00\u6b65\u90fd\u6709\u591a\u79cd\u9009\u62e9\uff08\u6bd4\u5982\u722c1\u9636\u62162\u9636\uff09\n- \u5230\u8fbe\u7b2cn\u9636\u7684\u65b9\u6cd5\u6570 = \u5230\u8fbe\u7b2c(n-1)\u9636\u7684\u65b9\u6cd5\u6570 + \u5230\u8fbe\u7b2c(n-2)\u9636\u7684\u65b9\u6cd5\u6570\n- \u6211\u4eec\u4e0d\u9700\u8981\u6bcf\u6b21\u90fd\u91cd\u65b0\u8ba1\u7b97\u524d\u9762\u7684\u6b65\u9aa4\uff0c\u800c\u662f\u8bb0\u4f4f\u4e4b\u524d\u7684\u7ed3\u679c\u76f4\u63a5\u4f7f\u7528\n\n---\n\n## \u8be6\u7ec6\u89e3\u7b54\n\n\u4e3a\u4e86\u66f4\u597d\u5730\u8bf4\u660e\u52a8\u6001\u89c4\u5212\uff0c\u6211\u4eec\u4ee5\u7ecf\u5178\u7684**\u6590\u6ce2\u90a3\u5951\u6570\u5217**\u4e3a\u4f8b\uff1a\n\n### \u65b9\u6cd5\u4e00\uff1a\u57fa\u7840\u89e3\u6cd5\uff08\u9012\u5f52+\u8bb0\u5fc6\u5316\uff09\n\n**\u601d\u8def\u8bf4\u660e**\uff1a\n- \u4f7f\u7528\u9012\u5f52\u5b9e\u73b0\uff0c\u4f46\u7528\u5b57\u5178\u5b58\u50a8\u5df2\u8ba1\u7b97\u7684\u7ed3\u679c\n- \u907f\u514d\u91cd\u590d\u8ba1\u7b97\u76f8\u540c\u7684\u5b50\u95ee\u9898\n\n```python\ndef fib_memo(n, memo={}):\n    if n in memo:\n        return memo[n]\n    if n <= 1:\n        return n\n    memo[n] = fib_memo(n-1, memo) + fib_memo(n-2, memo)\n    return memo[n]\n```\n\n**\u590d\u6742\u5ea6\u5206\u6790**\uff1a\n- \u65f6\u95f4\u590d\u6742\u5ea6\uff1aO(n) - \u6bcf\u4e2a\u6570\u5b57\u53ea\u8ba1\u7b97\u4e00\u6b21\n- \u7a7a\u95f4\u590d\u6742\u5ea6\uff1aO(n) - \u9012\u5f52\u6808\u6df1\u5ea6 + \u8bb0\u5fc6\u5316\u6570\u7ec4\n\n### \u65b9\u6cd5\u4e8c\uff1a\u4f18\u5316\u89e3\u6cd5\uff08\u63a8\u8350\uff09\n\n**\u4f18\u5316\u601d\u8def**\uff1a\n- \u4f7f\u7528\u81ea\u5e95\u5411\u4e0a\u7684\u8fed\u4ee3\u65b9\u5f0f\n- \u53ea\u4fdd\u7559\u5fc5\u8981\u7684\u72b6\u6001\uff0c\u8fdb\u4e00\u6b65\u4f18\u5316\u7a7a\u95f4\n\n```python\ndef fib_dp(n):\n    if n <= 1:\n        return n\n    \n    # \u53ea\u9700\u8981\u4fdd\u5b58\u524d\u4e24\u4e2a\u72b6\u6001\n    prev2, prev1 = 0, 1\n    for i in range(2, n + 1):\n        current = prev1 + prev2\n        prev2, prev1 = prev1, current\n    \n    return prev1\n```\n\n**\u590d\u6742\u5ea6\u5206\u6790**\uff1a\n- \u65f6\u95f4\u590d\u6742\u5ea6\uff1aO(n)\n- \u7a7a\u95f4\u590d\u6742\u5ea6\uff1aO(1) - \u53ea\u4f7f\u7528\u5e38\u6570\u989d\u5916\u7a7a\u95f4\n\n---\n\n## \u4ee3\u7801\u5b9e\u73b0\n\n\u4e0b\u9762\u63d0\u4f9b\u4e00\u4e2a\u5b8c\u6574\u7684\u52a8\u6001\u89c4\u5212\u6a21\u677f\uff0c\u4ee5**\u80cc\u5305\u95ee\u9898**\u4e3a\u4f8b\uff080-1\u80cc\u5305\uff09\uff1a\n\n```python\ndef solution():\n    # \u8f93\u5165\u5904\u7406\n    try:\n        n, capacity = map(int, input().split())\n        weights = list(map(int, input().split()))\n        values = list(map(int, input().split()))\n    except:\n        # \u9ed8\u8ba4\u6d4b\u8bd5\u6570\u636e\n        n, capacity = 3, 4\n        weights = [1, 3, 4]\n        values = [15, 20, 30]\n    \n    # DP\u6570\u7ec4\uff1adp[i][w] \u8868\u793a\u524di\u4e2a\u7269\u54c1\uff0c\u5728\u5bb9\u91cf\u4e3aw\u65f6\u7684\u6700\u5927\u4ef7\u503c\n    dp = [[0 for _ in range(capacity + 1)] for _ in range(n + 1)]\n    \n    # \u586b\u5145DP\u8868\n    for i in range(1, n + 1):\n        for w in range(capacity + 1):\n            # \u4e0d\u9009\u62e9\u7b2ci\u4e2a\u7269\u54c1\n            dp[i][w] = dp[i-1][w]\n            \n            # \u5982\u679c\u80fd\u9009\u62e9\u7b2ci\u4e2a\u7269\u54c1\uff0c\u6bd4\u8f83\u9009\u4e0e\u4e0d\u9009\u7684\u6700\u5927\u503c\n            if weights[i-1] <= w:\n                dp[i][w] = max(dp[i][w], dp[i-1][w - weights[i-1]] + values[i-1])\n    \n    print(dp[n][capacity])\n\nif __name__ == \"__main__\":\n    solution()\n```\n\n---\n\n## \u590d\u6742\u5ea6\u5206\u6790\n\n| \u6307\u6807 | \u590d\u6742\u5ea6 | \u8bf4\u660e |\n|------|--------|------|\n| \u65f6\u95f4\u590d\u6742\u5ea6 | O(n \u00d7 capacity) | \u9700\u8981\u586b\u5145\u4e8c\u7ef4DP\u8868\u7684\u6240\u6709\u4f4d\u7f6e |\n| \u7a7a\u95f4\u590d\u6742\u5ea6 | O(n \u00d7 capacity) | \u5b58\u50a8\u4e8c\u7ef4DP\u6570\u7ec4 |\n\n> **\u7a7a\u95f4\u4f18\u5316\u63d0\u793a**\uff1a\u7531\u4e8e\u6bcf\u6b21\u53ea\u4f9d\u8d56\u4e0a\u4e00\u884c\u7684\u72b6\u6001\uff0c\u53ef\u4ee5\u5c06\u7a7a\u95f4\u590d\u6742\u5ea6\u4f18\u5316\u5230O(capacity)\n\n---\n\n## \u76f8\u5173\u62d3\u5c55\n\n### **\u7c7b\u4f3c\u9898\u76ee**\n- **\u7ecf\u5178DP\u95ee\u9898**\uff1a\n  - \u6700\u957f\u9012\u589e\u5b50\u5e8f\u5217\uff08LIS\uff09\n  - \u6700\u957f\u516c\u5171\u5b50\u5e8f\u5217\uff08LCS\uff09\n  - \u7f16\u8f91\u8ddd\u79bb\n  - \u77e9\u9635\u94fe\u4e58\u6cd5\n  - \u6253\u5bb6\u52ab\u820d\u7cfb\u5217\n\n### **\u8fdb\u9636\u77e5\u8bc6**\n- **\u72b6\u6001\u538b\u7f29DP**\uff1a\u7528\u4f4d\u8fd0\u7b97\u4f18\u5316\u72b6\u6001\u8868\u793a\n- **\u533a\u95f4DP**\uff1a\u6309\u533a\u95f4\u957f\u5ea6\u9012\u63a8\uff08\u5982\u77f3\u5b50\u5408\u5e76\uff09\n- **\u6811\u5f62DP**\uff1a\u5728\u6811\u7ed3\u6784\u4e0a\u8fdb\u884c\u52a8\u6001\u89c4\u5212\n- **\u6570\u4f4dDP**\uff1a\u5904\u7406\u4e0e\u6570\u5b57\u5404\u4f4d\u76f8\u5173\u7684\u95ee\u9898\n- **\u6982\u7387DP**\uff1a\u5904\u7406\u5e26\u6709\u6982\u7387\u7684\u51b3\u7b56\u95ee\u9898\n\n### **\u5e38\u89c1\u9519\u8bef**\n- **\u72b6\u6001\u5b9a\u4e49\u4e0d\u6e05\u6670**\uff1a\u6ca1\u6709\u660e\u786e`dp[i]`\u7684\u5177\u4f53\u542b\u4e49\n- **\u8fb9\u754c\u6761\u4ef6\u9057\u6f0f**\uff1a\u5fd8\u8bb0\u5904\u7406\u7279\u6b8a\u60c5\u51b5\uff08\u5982n=0, n=1\uff09\n- **\u72b6\u6001\u8f6c\u79fb\u65b9\u7a0b\u9519\u8bef**\uff1a\u6ca1\u6709\u6b63\u786e\u5efa\u7acb\u72b6\u6001\u95f4\u7684\u4f9d\u8d56\u5173\u7cfb\n- **\u6570\u7ec4\u8d8a\u754c**\uff1a\u8bbf\u95ee\u4e86\u4e0d\u5b58\u5728\u7684DP\u72b6\u6001\n- **\u521d\u59cb\u5316\u9519\u8bef**\uff1a\u521d\u59cb\u503c\u8bbe\u7f6e\u4e0d\u5f53\u5bfc\u81f4\u540e\u7eed\u8ba1\u7b97\u9519\u8bef\n\n**\u907f\u514d\u65b9\u6cd5**\uff1a\n1. \u5148\u624b\u52a8\u6a21\u62df\u5c0f\u89c4\u6a21\u4f8b\u5b50\n2. \u660e\u786e\u5199\u51fa\u72b6\u6001\u5b9a\u4e49\u548c\u8f6c\u79fb\u65b9\u7a0b\n3. \u4ed4\u7ec6\u68c0\u67e5\u8fb9\u754c\u6761\u4ef6\n4. \u4f7f\u7528\u8c03\u8bd5\u5de5\u5177\u9a8c\u8bc1\u4e2d\u95f4\u7ed3\u679c", "additional_kwargs": {}, "response_metadata": {}, "type": "ai", "name": null, "id": null, "tool_calls": [], "invalid_tool_calls": [], "usage_metadata": null}}]